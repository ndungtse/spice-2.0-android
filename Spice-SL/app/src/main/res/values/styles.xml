<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="TextStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/inter_regular</item>
    </style>

    <style name="TextStyle_Bold" parent="TextStyle">
        <item name="android:textColor">@color/text_input_color</item>
        <item name="android:gravity">center</item>
        <item name="android:fontFamily">@font/inter_bold</item>
        <item name="android:textColorHint">@color/edittext_stroke</item>
    </style>

    <style name="TextStyle_Bold_16" parent="TextStyle_Bold">
        <item name="android:textSize">@dimen/_16ssp</item>
        <item name="android:background">@drawable/edittext_background</item>
    </style>

    <style name="TextStyle_Bold_16_NoBG" parent="TextStyle_Bold_16">
        <item name="android:background">@null</item>
    </style>

    <style name="TextStyle_Medium_20" parent="TextStyle_Medium">
        <item name="android:textSize">@dimen/_20ssp</item>
        <item name="font">@font/inter_medium</item>
    </style>

    <style name="TextStyle_Medium" parent="TextStyle">
        <item name="android:textColor">@color/text_input_color</item>
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="android:textColorHint">@color/edittext_stroke</item>
    </style>

    <style name="TextStyle_Regular_14" parent="TextStyle_Regular_12">
        <item name="android:textSize">@dimen/_14ssp</item>
    </style>

    <style name="TextStyle_Regular_12" parent="TextStyle">
        <item name="android:textSize">@dimen/_12ssp</item>
        <item name="android:textColor">@color/text_label_color</item>
    </style>

    <style name="Input_LayoutStyle_withoutToggle" parent="Input_LayoutStyle">
        <item name="passwordToggleEnabled">false</item>
        <item name="passwordToggleTint">@color/cobalt_blue</item>
    </style>

    <style name="Input_LayoutStyle" parent="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="boxBackgroundColor">@color/white</item>
        <item name="boxStrokeColor">@color/edittext_stroke</item>
        <item name="boxStrokeWidth">@dimen/_1sdp</item>
        <item name="hintAnimationEnabled">false</item>
        <item name="hintEnabled">false</item>
        <item name="passwordToggleEnabled">true</item>
        <item name="passwordToggleTint">@color/cobalt_blue</item>
    </style>

    <style name="Text_Long_Click_Style" parent="TextStyle_Regular_16_Rectangle_Bg">
        <item name="android:textSelectHandleLeft">@drawable/text_long_click_bg</item>
        <item name="android:textSelectHandleRight">@drawable/text_long_click_bg</item>
        <item name="android:textSelectHandle">@drawable/text_long_click_bg</item>
        <item name="android:textIsSelectable">false</item>
    </style>

    <style name="TextStyle_Regular_16_Rectangle_Bg" parent="TextStyle">
        <item name="android:textSize">@dimen/_16ssp</item>
        <item name="android:background">@drawable/edittext_background</item>
    </style>

    <style name="TextStyle_Error_12" parent="TextStyle">
        <item name="android:textSize">@dimen/_12ssp</item>
        <item name="android:textColor">@color/a_red_error</item>
    </style>

    <style name="CheckBox_Style" parent="TextStyle_Regular_14">
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="Button_Style">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/button_cobalt_bg</item>
        <item name="android:fontFamily">@font/inter_regular</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/_14ssp</item>
        <item name="android:paddingStart">@dimen/_30sdp</item>
        <item name="android:paddingEnd">@dimen/_30sdp</item>
        <item name="android:paddingTop">@dimen/_10sdp</item>
        <item name="android:paddingBottom">@dimen/_10sdp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="Button_Style_Plain" parent="TextStyle_Medium_14_NoBG">
        <item name="android:textSize">@dimen/_14ssp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="TextStyle_Medium_14_NoBG" parent="TextStyle_Medium_14">
        <item name="android:background">@null</item>
    </style>

    <style name="TextStyle_Medium_14" parent="TextStyle_Medium">
        <item name="android:textSize">@dimen/_14ssp</item>
        <item name="android:background">@drawable/edittext_background</item>
    </style>

</resources>