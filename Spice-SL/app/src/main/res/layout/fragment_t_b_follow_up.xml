<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:bind="http://schemas.android.com/tools">

    <com.google.android.material.card.MaterialCardView
        style="@style/CardView_Style"
        android:layout_marginVertical="@dimen/_6sdp"
        app:cardUseCompatPadding="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/divider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/card_background">

                <TextView
                    android:id="@+id/followupCardTitle"
                    style="@style/Form_Header_Style"
                    android:layout_width="@dimen/_0dp"
                    android:gravity="center"
                    android:paddingHorizontal="@dimen/_16sdp"
                    android:paddingVertical="@dimen/_10sdp"
                    android:text="@string/follow_up"
                    android:textSize="@dimen/_16ssp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />


            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:animateLayoutChanges="true"
                android:orientation="vertical"
                android:padding="@dimen/_16sdp"
                app:layout_constraintTop_toBottomOf="@+id/divider">


                <TextView
                    android:id="@+id/emptyErrorMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_horizontal|center_vertical"
                    android:paddingVertical="@dimen/_32sdp"
                    android:text="@string/patient_followup_details_error"
                    android:textColor="@color/red_risk"
                    android:textSize="@dimen/_16ssp"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/llParentLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvNextFollowupDateTitle"
                        style="@style/Form_Label_Style"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_16sdp"
                        android:text="@string/rx_buddy_monitoring_sheet" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/etNextFollowUpDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="date"
                        style="@style/Form_Input_Style"
                        android:drawableEnd="@drawable/referral_calendar_icon"
                        android:gravity="start|center"
                        android:layout_marginVertical="@dimen/_8sdp"
                        android:textColor="@color/black"
                        android:hint="@string/dd_mm_yyyy"
                        android:textSize="@dimen/_16ssp"
                        android:paddingStart="@dimen/_4sdp" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvSymptomsWorse"
                        style="@style/TextStyle_Regular_14_Size_Title_color"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/_4sdp"
                        android:visibility="visible"
                        android:text="@string/any_of_your_symptoms_getting_worse" />

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:id="@+id/SymptomsWorseRoot"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/_4sdp"
                        android:layout_marginEnd="@dimen/_4sdp"
                        android:layout_marginBottom="@dimen/_8sdp"
                        android:orientation="horizontal">

                    </androidx.appcompat.widget.LinearLayoutCompat>

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvSymptomsWorseErrorMessage"
                        style="@style/TextStyle_Error_14"
                        android:paddingHorizontal="@dimen/_8sdp"
                        android:paddingVertical="@dimen/_8sdp"
                        android:text="@string/default_user_input_error"
                        android:visibility="gone"
                        app:layout_constraintStart_toStartOf="parent" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvMedication"
                        style="@style/TextStyle_Regular_14_Size_Title_color"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/_4sdp"
                        android:visibility="visible"
                        android:text="@string/have_you_had_a_reaction_to_any_of_your_medications" />

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:id="@+id/MedicationRoot"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/_4sdp"
                        android:layout_marginEnd="@dimen/_4sdp"
                        android:layout_marginBottom="@dimen/_8sdp"
                        android:orientation="horizontal">

                    </androidx.appcompat.widget.LinearLayoutCompat>

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvMedicationErrorMessage"
                        style="@style/TextStyle_Error_14"
                        android:paddingHorizontal="@dimen/_8sdp"
                        android:paddingVertical="@dimen/_8sdp"
                        android:text="@string/default_user_input_error"
                        android:visibility="gone"
                        app:layout_constraintStart_toStartOf="parent" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>


</LinearLayout>