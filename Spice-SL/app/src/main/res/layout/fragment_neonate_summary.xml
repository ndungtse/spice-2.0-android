<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/CardView_Style"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardUseCompatPadding="true"
    tools:context=".ui.mypatients.fragment.NeonateSummaryFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <View
            android:id="@+id/viewNeonateFragment"
            android:layout_width="0dp"
            android:layout_height="@dimen/_0dp"
            android:background="@color/card_background"
            app:layout_constraintBottom_toBottomOf="@id/tvNeonateFragment"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvNeonateFragment"
            style="@style/Form_Header_Style"
            android:layout_width="0dp"
            android:gravity="center"
            android:paddingHorizontal="@dimen/_10sdp"
            android:paddingVertical="@dimen/_10sdp"
            android:text="@string/title_neonate"
            android:textSize="@dimen/_16ssp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="@+id/viewNeonateFragment"
            app:layout_constraintStart_toStartOf="@+id/viewNeonateFragment"
            app:layout_constraintTop_toTopOf="@+id/viewNeonateFragment" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/startGuideline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.2" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/endGuideline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.25" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvNeonateOutcomeLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_16sdp"
            android:layout_marginTop="@dimen/_16sdp"
            android:text="@string/neonate_outcome"
            android:textSize="@dimen/_18ssp"
            android:textColor="@color/table_title"
            app:layout_constraintEnd_toStartOf="@+id/startGuideline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvNeonateFragment" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/seperatorColon1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/separator_colon"
            app:layout_constraintEnd_toStartOf="@+id/endGuideline"
            app:layout_constraintStart_toStartOf="@+id/startGuideline"
            app:layout_constraintTop_toTopOf="@+id/tvNeonateOutcomeLabel" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvNeonateOutcome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/_16sdp"
            android:text="Live birth"
            android:textSize="@dimen/_18ssp"
            android:textColor="@color/grey_black"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/endGuideline"
            app:layout_constraintTop_toTopOf="@+id/tvNeonateOutcomeLabel" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvGenderLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_16sdp"
            android:text="@string/gender"
            android:textSize="@dimen/_18ssp"
            android:textColor="@color/table_title"
            app:layout_constraintEnd_toEndOf="@+id/startGuideline"
            app:layout_constraintStart_toStartOf="@id/tvNeonateOutcomeLabel"
            app:layout_constraintTop_toBottomOf="@+id/tvNeonateOutcomeLabel" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/seperatorColon2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/separator_colon"
            app:layout_constraintEnd_toStartOf="@+id/endGuideline"
            app:layout_constraintStart_toStartOf="@+id/startGuideline"
            app:layout_constraintTop_toTopOf="@+id/tvGenderLabel" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvGender"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/_16sdp"
            android:text="Female"
            android:textSize="@dimen/_18ssp"
            android:textColor="@color/grey_black"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/endGuideline"
            app:layout_constraintTop_toTopOf="@+id/tvGenderLabel" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvBirthWeightLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_16sdp"
            android:text="@string/birth_weight"
            android:textSize="@dimen/_18ssp"
            android:textColor="@color/table_title"
            app:layout_constraintEnd_toEndOf="@+id/startGuideline"
            app:layout_constraintStart_toStartOf="@id/tvGenderLabel"
            app:layout_constraintTop_toBottomOf="@+id/tvGenderLabel" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/seperatorColon3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/separator_colon"
            app:layout_constraintEnd_toStartOf="@+id/endGuideline"
            app:layout_constraintStart_toStartOf="@+id/startGuideline"
            app:layout_constraintTop_toTopOf="@+id/tvBirthWeightLabel" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvBirthWeight"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/_16sdp"
            android:text="3kgs"
            android:textSize="@dimen/_18ssp"
            android:textColor="@color/grey_black"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/endGuideline"
            app:layout_constraintTop_toTopOf="@+id/tvBirthWeightLabel" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvStateOfBabyLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_16sdp"
            android:text="@string/state_of_the_baby"
            android:textSize="@dimen/_18ssp"
            android:textColor="@color/table_title"
            app:layout_constraintEnd_toEndOf="@+id/startGuideline"
            app:layout_constraintStart_toStartOf="@id/tvBirthWeightLabel"
            app:layout_constraintTop_toBottomOf="@+id/tvBirthWeightLabel" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/seperatorColon4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/separator_colon"
            app:layout_constraintEnd_toStartOf="@+id/endGuideline"
            app:layout_constraintStart_toStartOf="@+id/startGuideline"
            app:layout_constraintTop_toTopOf="@+id/tvStateOfBabyLabel" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvStateOfBaby"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/_16sdp"
            android:text="Normal"
            android:textSize="@dimen/_18ssp"
            android:textColor="@color/grey_black"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/endGuideline"
            app:layout_constraintTop_toTopOf="@+id/tvStateOfBabyLabel" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvGestationalAgeLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_16sdp"
            android:text="@string/gestational_age"
            android:textSize="@dimen/_18ssp"
            android:textColor="@color/table_title"
            app:layout_constraintEnd_toEndOf="@+id/startGuideline"
            app:layout_constraintStart_toStartOf="@id/tvStateOfBabyLabel"
            app:layout_constraintTop_toBottomOf="@+id/tvStateOfBabyLabel" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/seperatorColon5"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/separator_colon"
            app:layout_constraintEnd_toStartOf="@+id/endGuideline"
            app:layout_constraintStart_toStartOf="@+id/startGuideline"
            app:layout_constraintTop_toTopOf="@+id/tvGestationalAgeLabel" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvGestationalAge"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/_16sdp"
            android:text="33 weeks"
            android:textSize="@dimen/_18ssp"
            android:textColor="@color/grey_black"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/endGuideline"
            app:layout_constraintTop_toTopOf="@+id/tvGestationalAgeLabel" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvAPGARScoreLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_16sdp"
            android:text="@string/apgar_score"
            android:textSize="@dimen/_18ssp"
            android:textColor="@color/table_title"
            app:layout_constraintEnd_toEndOf="@+id/startGuideline"
            app:layout_constraintStart_toStartOf="@id/tvGestationalAgeLabel"
            app:layout_constraintTop_toBottomOf="@+id/tvGestationalAgeLabel" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/seperatorColon6"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/separator_colon"
            app:layout_constraintEnd_toStartOf="@+id/endGuideline"
            app:layout_constraintStart_toStartOf="@+id/startGuideline"
            app:layout_constraintTop_toTopOf="@+id/tvAPGARScoreLabel" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvAPGARScore"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/_16sdp"
            android:text="10 (Five minutes)"
            android:textSize="@dimen/_18ssp"
            android:textColor="@color/grey_black"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/endGuideline"
            app:layout_constraintTop_toTopOf="@+id/tvAPGARScoreLabel" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvSignsSymptomsObservedLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_16sdp"
            android:text="@string/signs_symptoms_observed"
            android:textSize="@dimen/_18ssp"
            android:textColor="@color/table_title"
            app:layout_constraintBottom_toTopOf="@id/groupSignSymptomsObserved"
            app:layout_constraintEnd_toEndOf="@+id/startGuideline"
            app:layout_constraintStart_toStartOf="@id/tvAPGARScoreLabel"
            app:layout_constraintTop_toBottomOf="@+id/tvAPGARScoreLabel" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/seperatorColon7"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/separator_colon"
            app:layout_constraintEnd_toStartOf="@+id/endGuideline"
            app:layout_constraintStart_toStartOf="@+id/startGuideline"
            app:layout_constraintTop_toTopOf="@+id/tvSignsSymptomsObservedLabel" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvSignsSymptomsObserved"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/_16sdp"
            android:text="Breast-fed within 1hour Still alive"
            android:textSize="@dimen/_18ssp"
            android:textColor="@color/grey_black"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/endGuideline"
            app:layout_constraintTop_toTopOf="@+id/tvSignsSymptomsObservedLabel" />

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/groupSignSymptomsObserved"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:barrierDirection="bottom"
            app:layout_constraintBottom_toBottomOf="@id/tvSignsSymptomsObservedLabel"
            app:layout_constraintTop_toTopOf="@id/tvPatientStatusLabel"
            app:constraint_referenced_ids="tvSignsSymptomsObservedLabel,tvSignsSymptomsObserved" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvPatientStatusLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_16sdp"
            android:paddingBottom="@dimen/_16sdp"
            android:text="@string/patient_status"
            android:textSize="@dimen/_18ssp"
            android:textColor="@color/table_title"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@+id/startGuideline"
            app:layout_constraintStart_toStartOf="@id/tvSignsSymptomsObservedLabel"
            app:layout_constraintTop_toBottomOf="@+id/groupSignSymptomsObserved" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/seperatorColon8"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/separator_colon"
            app:layout_constraintEnd_toStartOf="@+id/endGuideline"
            app:layout_constraintStart_toStartOf="@+id/startGuideline"
            app:layout_constraintTop_toTopOf="@+id/tvPatientStatusLabel" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvPatientStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/_16sdp"
            android:text="Neonate"
            android:textSize="@dimen/_18ssp"
            android:textColor="@color/grey_black"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/endGuideline"
            app:layout_constraintTop_toTopOf="@+id/tvPatientStatusLabel" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>