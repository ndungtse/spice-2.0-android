<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <androidx.cardview.widget.CardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="@dimen/_8sdp"
        app:cardElevation="@dimen/_4sdp"
        app:cardUseCompatPadding="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="@dimen/_280sdp"
            android:layout_height="wrap_content"
            android:paddingBottom="@dimen/_10sdp">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvImmunisationName"
                style="@style/Form_Header_Style"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                android:background="@drawable/gradiant_background"
                android:drawableEnd="@drawable/ic_black_forward_direction"
                android:gravity="start"
                android:padding="@dimen/_16sdp"
                android:text="BCG"
                android:textColor="@color/house_hold_title"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guideline_35"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.35" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/immunisationDate"
                style="@style/TextStyle"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                android:gravity="start"
                android:padding="@dimen/_16sdp"
                android:text="@string/date"
                android:textColor="@color/table_title"
                app:layout_constraintEnd_toStartOf="@id/guideline_35"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvImmunisationName" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/immunisationDateSeparator"
                style="@style/TextStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/semicolon"
                android:textColor="@color/table_title"
                app:layout_constraintBottom_toBottomOf="@+id/immunisationDate"
                app:layout_constraintStart_toEndOf="@+id/guideline_35"
                app:layout_constraintTop_toTopOf="@+id/immunisationDate" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvImmunisationDate"
                style="@style/TextStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_16sdp"
                android:text="08/01/2024"
                android:textColor="@color/grey_black"
                app:layout_constraintBottom_toBottomOf="@+id/immunisationDate"
                app:layout_constraintStart_toStartOf="@+id/guideline_35"
                app:layout_constraintTop_toTopOf="@+id/immunisationDate" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/immunisationStatus"
                style="@style/TextStyle"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                android:gravity="start"
                android:padding="@dimen/_16sdp"
                android:text="@string/status"
                android:textColor="@color/table_title"
                app:layout_constraintBottom_toBottomOf="@+id/flEpiStatusNudge"
                app:layout_constraintEnd_toStartOf="@id/guideline_35"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/flEpiStatusNudge" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/immunisationStatusSeparator"
                style="@style/TextStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/semicolon"
                android:textColor="@color/table_title"
                app:layout_constraintBottom_toBottomOf="@+id/flEpiStatusNudge"
                app:layout_constraintStart_toEndOf="@+id/guideline_35"
                app:layout_constraintTop_toTopOf="@+id/flEpiStatusNudge" />

            <FrameLayout
                android:id="@+id/flEpiStatusNudge"
                layout="@layout/view_vaccination_status_nudge"
                android:layout_width="@dimen/_142sdp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_16sdp"
                android:minHeight="@dimen/_44sdp"
                app:layout_constraintStart_toStartOf="@+id/guideline_35"
                app:layout_constraintTop_toBottomOf="@+id/immunisationDate" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>