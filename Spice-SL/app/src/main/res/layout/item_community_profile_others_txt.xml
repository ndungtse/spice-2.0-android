<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/_4sdp"
    android:background="@drawable/bg_card_statistics">

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvLabelName"
        style="@style/TextStyle_Bold_14_black_Medium"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:padding="@dimen/_12sdp"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintEnd_toStartOf="@+id/tvText"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Total population in thid community herkkoe weoiujlkjhkj " />


    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvText"
        style="@style/TextStyle_Bold_16_Medium_Blue"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:background="@drawable/bg_statistics_text"
        android:ellipsize="end"
        android:maxWidth="@dimen/_300sdp"
        android:gravity="end"
        android:padding="@dimen/_12sdp"
        android:visibility="visible"
        app:layout_constraintStart_toEndOf="@+id/tvLabelName"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:text="kljkklj kjtdfsd fsdfasddadsfsdfasdfasdfasdasdfasdfasdfasdfasdfasdfasdf asdfasdfs dfsdfsdfsddsfd hea" />

</androidx.constraintlayout.widget.ConstraintLayout>