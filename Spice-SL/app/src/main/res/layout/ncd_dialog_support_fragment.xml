<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/_10sdp"
        android:layout_marginVertical="@dimen/_10sdp"
        android:animateLayoutChanges="true"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            style="@style/CardView_Style"
            android:layout_height="match_parent"
            android:layout_marginVertical="@dimen/_6sdp"
            app:cardUseCompatPadding="true">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:id="@+id/titleCard"
                    android:layout_width="@dimen/_0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <org.medtroniclabs.uhis.ui.DialogTitleFrameLayout
                        android:id="@+id/labelHeader"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:dialogTitle="@string/support"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </LinearLayout>

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/enterSummary"
                    android:layout_width="@dimen/_0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/support_label"
                    android:textSize="@dimen/_16ssp"
                    android:fontFamily="@font/inter_regular"
                    android:layout_marginTop="@dimen/_16sdp"
                    android:textColor="@color/b_w_black"
                    app:layout_constraintEnd_toEndOf="@+id/etSupportText"
                    app:layout_constraintTop_toBottomOf="@+id/titleCard"
                    app:layout_constraintStart_toStartOf="@+id/etSupportText" />

                <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/etSupportText"
                    android:layout_width="@dimen/_0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/_120sdp"
                    style="@style/Form_Input_Style"
                    android:maxLength="255"
                    android:inputType="textMultiLine"
                    android:gravity="top"
                    app:layout_constraintVertical_bias="0.0"
                    android:hint="@string/comments"
                    android:padding="@dimen/_8sdp"
                    android:layout_margin="@dimen/_16sdp"
                    android:background="@drawable/edittext_background"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/enterSummary"
                    app:layout_constraintBottom_toTopOf="@+id/bottomDivider"/>

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvSummaryError"
                    style="@style/TextStyle_Error_12"
                    android:visibility="gone"
                    android:text="@string/default_user_input_error"
                    android:layout_marginStart="@dimen/_16sdp"
                    android:layout_marginEnd="@dimen/_16sdp"
                    android:layout_marginTop="@dimen/_4sdp"
                    app:layout_constraintStart_toStartOf="@id/etSupportText"
                    app:layout_constraintEnd_toEndOf="@id/etSupportText"
                    app:layout_constraintTop_toBottomOf="@+id/etSupportText"/>

                <View
                    android:id="@+id/bottomDivider"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_1sdp"
                    android:layout_marginTop="@dimen/_8sdp"
                    android:layout_marginBottom="@dimen/_16sdp"
                    android:background="@color/edittext_stroke"
                    app:layout_constraintBottom_toTopOf="@+id/btnSubmit"
                    app:layout_constraintTop_toBottomOf="@id/tvSummaryError"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnSubmit"
                    style="@style/Button_Style"
                    android:layout_width="@dimen/_0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/_24sdp"
                    android:background="@drawable/btn_bg_selector"
                    android:minWidth="@dimen/_100sdp"
                    android:enabled="false"
                    android:text="@string/submit"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="@+id/etSupportText"
                    app:layout_constraintStart_toStartOf="@+id/etSupportText"
                    />


            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
