<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/fragment_bg">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardSummary"
        style="@style/CardView_Style"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/_10sdp"
        android:layout_marginTop="@dimen/_10sdp"
        android:layout_marginEnd="@dimen/_10sdp"
        app:cardCornerRadius="@dimen/_10sdp"
        app:layout_constraintBottom_toTopOf="@id/tvClinicalNameLabel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeWidth="@dimen/_0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvTitle"
                style="@style/Form_Header_Style"
                android:layout_width="0dp"
                android:background="@color/grey_bg"
                android:gravity="center"
                android:padding="@dimen/_10sdp"
                android:text="@string/summary"
                android:textSize="@dimen/_16ssp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/startGuideline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_begin="@dimen/_16sdp" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/endGuideline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_end="@dimen/_16sdp" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvDiagnosesLabel"
                style="@style/TextStyle_Regular_16"
                android:layout_width="@dimen/_0dp"
                android:layout_marginTop="@dimen/_10sdp"
                android:text="@string/diagnosis_tb"
                app:layout_constraintEnd_toStartOf="@id/tvDiagnosesSeparator"
                app:layout_constraintHorizontal_weight="0.3"
                app:layout_constraintStart_toEndOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@id/tvTitle" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvDiagnosesSeparator"
                style="@style/TextStyle_Regular_16"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:text="@string/separator_colon"
                app:layout_constraintEnd_toStartOf="@id/tvDiagnosesText"
                app:layout_constraintHorizontal_weight="0.05"
                app:layout_constraintStart_toEndOf="@id/tvDiagnosesLabel"
                app:layout_constraintTop_toTopOf="@id/tvDiagnosesLabel" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvDiagnosesText"
                style="@style/TextStyle_Regular_16_Bold"
                android:layout_width="@dimen/_0dp"
                android:text="@string/seperator_hyphen"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintHorizontal_weight="0.6"
                app:layout_constraintStart_toEndOf="@id/tvDiagnosesSeparator"
                app:layout_constraintTop_toTopOf="@id/tvDiagnosesLabel" />

            <androidx.constraintlayout.widget.Barrier
                android:id="@+id/barrierOne"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="tvDiagnosesText" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvSiteLabel"
                style="@style/TextStyle_Regular_16"
                android:layout_width="@dimen/_0dp"
                android:layout_marginTop="@dimen/_16sdp"
                android:text="@string/site_of_disease"
                app:layout_constraintEnd_toStartOf="@id/tvSiteSeparator"
                app:layout_constraintHorizontal_weight="0.3"
                app:layout_constraintStart_toEndOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@id/barrierOne" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvSiteSeparator"
                style="@style/TextStyle_Regular_16"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:text="@string/separator_colon"
                app:layout_constraintEnd_toStartOf="@id/tvSiteText"
                app:layout_constraintHorizontal_weight="0.05"
                app:layout_constraintStart_toEndOf="@id/tvSiteLabel"
                app:layout_constraintTop_toTopOf="@id/tvSiteLabel" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvSiteText"
                style="@style/TextStyle_Regular_16_Bold"
                android:layout_width="@dimen/_0dp"
                android:text="@string/seperator_hyphen"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintHorizontal_weight="0.6"
                app:layout_constraintStart_toEndOf="@id/tvSiteSeparator"
                app:layout_constraintTop_toTopOf="@id/tvSiteLabel" />

            <androidx.constraintlayout.widget.Barrier
                android:id="@+id/barrierOther"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="tvSiteText" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvPatientStatus"
                style="@style/TextStyle_Regular_16"
                android:layout_width="@dimen/_0dp"
                android:layout_marginTop="@dimen/_16sdp"
                android:text="@string/patient_status"
                app:layout_constraintEnd_toStartOf="@id/tvPatientSeparator"
                app:layout_constraintHorizontal_weight="0.3"
                app:layout_constraintStart_toEndOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@id/barrierOther" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvPatientSeparator"
                style="@style/TextStyle_Regular_16"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:text="@string/separator_colon"
                app:layout_constraintEnd_toStartOf="@id/tvPatientStatusSpinner"
                app:layout_constraintHorizontal_weight="0.05"
                app:layout_constraintStart_toEndOf="@id/tvPatientStatus"
                app:layout_constraintTop_toTopOf="@id/tvPatientStatus" />

            <androidx.appcompat.widget.AppCompatSpinner
                android:id="@+id/tvPatientStatusSpinner"
                style="@style/Form_Spinner_Style"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="@id/tvPatientStatus"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintHorizontal_weight="0.6"
                app:layout_constraintStart_toEndOf="@id/tvPatientSeparator"
                app:layout_constraintTop_toTopOf="@id/tvPatientStatus" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvPatientError"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_regular"
                android:padding="@dimen/_5sdp"
                android:text="@string/default_user_input_error"
                android:textColor="@color/a_red_error"
                android:textSize="@dimen/_12ssp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="@id/tvPatientStatusSpinner"
                app:layout_constraintStart_toStartOf="@id/tvPatientStatusSpinner"
                app:layout_constraintTop_toBottomOf="@id/tvPatientStatusSpinner" />

            <androidx.constraintlayout.widget.Barrier
                android:id="@+id/barrierTwo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="tvPatientError, tvPatientStatus" />
            <androidx.constraintlayout.widget.Group
                android:id="@+id/eMTCTSummaryGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:constraint_referenced_ids="tvMaternalOutcomeText,tvMaternalOutcomeSeparator,tvMaternalOutcome,tvEmtctVisitStatusText,tvEmtctVisitStatus, tvEmtctVisitStatusSeparator" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvEmtctVisitStatus"
                style="@style/TextStyle_Regular_16"
                android:layout_width="@dimen/_0dp"
                android:layout_marginTop="@dimen/_16sdp"
                android:text="@string/emtct_visit_status"
                app:layout_constraintEnd_toStartOf="@id/tvEmtctVisitStatusSeparator"
                app:layout_constraintHorizontal_weight="0.3"
                app:layout_constraintStart_toEndOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@id/barrierTwo" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvEmtctVisitStatusSeparator"
                style="@style/TextStyle_Regular_16"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:text="@string/separator_colon"
                app:layout_constraintEnd_toStartOf="@id/tvEmtctVisitStatusText"
                app:layout_constraintHorizontal_weight="0.05"
                app:layout_constraintStart_toEndOf="@id/tvEmtctVisitStatus"
                app:layout_constraintTop_toTopOf="@id/tvEmtctVisitStatus" />

            <androidx.appcompat.widget.AppCompatSpinner
                android:id="@+id/tvEmtctVisitStatusText"
                style="@style/Form_Spinner_Style"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toTopOf="@id/barrierEleven"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintHorizontal_weight="0.6"
                app:layout_constraintStart_toEndOf="@id/tvEmtctVisitStatusSeparator"
                app:layout_constraintTop_toTopOf="@id/tvEmtctVisitStatus" />
            <androidx.constraintlayout.widget.Barrier
                android:id="@+id/barrierEleven"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="tvEmtctVisitStatus,tvEmtctVisitStatusText, tvEmtctVisitStatusSeparator" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvMaternalOutcome"
                style="@style/TextStyle_Regular_16"
                android:layout_width="@dimen/_0dp"
                android:layout_marginTop="@dimen/_16sdp"
                android:text="@string/maternal_outcome"
                app:layout_constraintEnd_toStartOf="@id/tvMaternalOutcomeSeparator"
                app:layout_constraintHorizontal_weight="0.3"
                app:layout_constraintStart_toEndOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@id/barrierEleven" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvMaternalOutcomeSeparator"
                style="@style/TextStyle_Regular_16"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:text="@string/separator_colon"
                app:layout_constraintEnd_toStartOf="@id/tvMaternalOutcomeText"
                app:layout_constraintHorizontal_weight="0.05"
                app:layout_constraintStart_toEndOf="@id/tvMaternalOutcome"
                app:layout_constraintTop_toTopOf="@id/tvMaternalOutcome" />

            <androidx.appcompat.widget.AppCompatSpinner
                android:id="@+id/tvMaternalOutcomeText"
                style="@style/Form_Spinner_Style"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toTopOf="@id/barrierTwelve"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintHorizontal_weight="0.6"
                app:layout_constraintStart_toEndOf="@id/tvMaternalOutcomeSeparator"
                app:layout_constraintTop_toTopOf="@id/tvMaternalOutcome"/>
            <androidx.constraintlayout.widget.Barrier
                android:id="@+id/barrierTwelve"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="tvMaternalOutcomeText,tvMaternalOutcome" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvPresentingLabel"
                style="@style/TextStyle_Regular_16"
                android:layout_width="@dimen/_0dp"
                android:layout_marginTop="@dimen/_16sdp"
                android:text="@string/presenting_complaints"
                app:layout_constraintEnd_toStartOf="@id/tvPresentingSeparator"
                app:layout_constraintHorizontal_weight="0.3"
                app:layout_constraintStart_toEndOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@id/barrierTwelve" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvPresentingSeparator"
                style="@style/TextStyle_Regular_16"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:text="@string/separator_colon"
                app:layout_constraintEnd_toStartOf="@id/tvPresentingText"
                app:layout_constraintHorizontal_weight="0.05"
                app:layout_constraintStart_toEndOf="@id/tvPresentingLabel"
                app:layout_constraintTop_toTopOf="@id/tvPresentingLabel" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvPresentingText"
                style="@style/TextStyle_Regular_16_Bold"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                android:text="@string/seperator_hyphen"
                app:layout_constraintBottom_toTopOf="@id/barrierFour"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintHorizontal_weight="0.6"
                app:layout_constraintStart_toEndOf="@id/tvPresentingSeparator"
                app:layout_constraintTop_toTopOf="@id/tvPresentingLabel" />

            <androidx.constraintlayout.widget.Barrier
                android:id="@+id/barrierFour"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="tvPresentingLabel, tvPresentingText" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvComborbiditiesLabel"
                style="@style/TextStyle_Regular_16"
                android:layout_width="@dimen/_0dp"
                android:layout_marginTop="@dimen/_16sdp"
                android:text="@string/comorbidities"
                app:layout_constraintEnd_toStartOf="@id/tvComborbiditiesSeparator"
                app:layout_constraintHorizontal_weight="0.3"
                app:layout_constraintStart_toEndOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@id/barrierFour" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvComborbiditiesSeparator"
                style="@style/TextStyle_Regular_16"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:text="@string/separator_colon"
                app:layout_constraintEnd_toStartOf="@id/tvComborbiditiesText"
                app:layout_constraintHorizontal_weight="0.05"
                app:layout_constraintStart_toEndOf="@id/tvComborbiditiesLabel"
                app:layout_constraintTop_toTopOf="@id/tvComborbiditiesLabel" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvComborbiditiesText"
                style="@style/TextStyle_Regular_16_Bold"
                android:layout_width="@dimen/_0dp"
                android:text="@string/seperator_hyphen"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintHorizontal_weight="0.6"
                app:layout_constraintStart_toEndOf="@id/tvComborbiditiesSeparator"
                app:layout_constraintTop_toTopOf="@id/tvComborbiditiesLabel" />

            <androidx.constraintlayout.widget.Barrier
                android:id="@+id/barrierFive"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="tvComborbiditiesLabel, tvComborbiditiesText" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvGeneralLabel"
                style="@style/TextStyle_Regular_16"
                android:layout_width="@dimen/_0dp"
                android:layout_marginTop="@dimen/_16sdp"
                android:text="@string/general_systemic_examinations"
                app:layout_constraintEnd_toStartOf="@id/tvGeneralSeparator"
                app:layout_constraintHorizontal_weight="0.3"
                app:layout_constraintStart_toEndOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@id/barrierFive" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvGeneralSeparator"
                style="@style/TextStyle_Regular_16"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:text="@string/separator_colon"
                app:layout_constraintEnd_toStartOf="@id/tvGeneralText"
                app:layout_constraintHorizontal_weight="0.05"
                app:layout_constraintStart_toEndOf="@id/tvGeneralLabel"
                app:layout_constraintTop_toTopOf="@id/tvGeneralLabel" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvGeneralText"
                style="@style/TextStyle_Regular_16_Bold"
                android:layout_width="@dimen/_0dp"
                android:text="@string/seperator_hyphen"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintHorizontal_weight="0.6"
                app:layout_constraintStart_toEndOf="@id/tvGeneralSeparator"
                app:layout_constraintTop_toTopOf="@id/tvGeneralLabel" />

            <androidx.constraintlayout.widget.Barrier
                android:id="@+id/barrierSix"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="tvGeneralLabel, tvGeneralText" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvClinicalNotesLabel"
                style="@style/TextStyle_Regular_16"
                android:layout_width="@dimen/_0dp"
                android:layout_marginTop="@dimen/_16sdp"
                android:text="@string/clinical_notes"
                app:layout_constraintEnd_toStartOf="@id/tvClinicalNotesSeparator"
                app:layout_constraintHorizontal_weight="0.3"
                app:layout_constraintStart_toEndOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@id/barrierSix" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvClinicalNotesSeparator"
                style="@style/TextStyle_Regular_16"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:text="@string/separator_colon"
                app:layout_constraintEnd_toStartOf="@id/tvClinicalNotesText"
                app:layout_constraintHorizontal_weight="0.05"
                app:layout_constraintStart_toEndOf="@id/tvClinicalNotesLabel"
                app:layout_constraintTop_toTopOf="@id/tvClinicalNotesLabel" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvClinicalNotesText"
                style="@style/TextStyle_Regular_16_Bold"
                android:layout_width="@dimen/_0dp"
                android:text="@string/seperator_hyphen"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintHorizontal_weight="0.6"
                app:layout_constraintStart_toEndOf="@id/tvClinicalNotesSeparator"
                app:layout_constraintTop_toTopOf="@id/tvClinicalNotesLabel" />

            <androidx.constraintlayout.widget.Barrier
                android:id="@+id/barrierSeven"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="tvClinicalNotesText, tvClinicalNotesLabel" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvInvestigationLabel"
                style="@style/TextStyle_Regular_16"
                android:layout_width="@dimen/_0dp"
                android:layout_marginTop="@dimen/_16sdp"
                android:text="@string/investigation"
                app:layout_constraintEnd_toStartOf="@id/tvInvestigationSeparator"
                app:layout_constraintHorizontal_weight="0.3"
                app:layout_constraintStart_toEndOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@id/barrierSeven" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvInvestigationSeparator"
                style="@style/TextStyle_Regular_16"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:text="@string/separator_colon"
                app:layout_constraintEnd_toStartOf="@id/tvInvestigationText"
                app:layout_constraintHorizontal_weight="0.05"
                app:layout_constraintStart_toEndOf="@id/tvInvestigationLabel"
                app:layout_constraintTop_toTopOf="@id/tvInvestigationLabel" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvInvestigationText"
                style="@style/TextStyle_Regular_16_Bold"
                android:layout_width="@dimen/_0dp"
                android:text="@string/seperator_hyphen"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintHorizontal_weight="0.6"
                app:layout_constraintStart_toEndOf="@id/tvInvestigationSeparator"
                app:layout_constraintTop_toTopOf="@id/tvInvestigationLabel" />

            <androidx.constraintlayout.widget.Barrier
                android:id="@+id/barrierTen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="tvInvestigationText, tvInvestigationLabel" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvPrescrptionlabel"
                style="@style/TextStyle_Regular_16"
                android:layout_width="@dimen/_0dp"
                android:layout_marginTop="@dimen/_16sdp"
                android:text="@string/prescription"
                app:layout_constraintEnd_toStartOf="@id/tvPrescrptionSeparator"
                app:layout_constraintHorizontal_weight="0.3"
                app:layout_constraintStart_toEndOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@id/barrierTen" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvPrescrptionSeparator"
                style="@style/TextStyle_Regular_16"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:text="@string/separator_colon"
                app:layout_constraintEnd_toStartOf="@id/tvPrescrptionText"
                app:layout_constraintHorizontal_weight="0.05"
                app:layout_constraintStart_toEndOf="@id/tvPrescrptionlabel"
                app:layout_constraintTop_toTopOf="@id/tvPrescrptionlabel" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvPrescrptionText"
                style="@style/TextStyle_Regular_16_Bold"
                android:layout_width="@dimen/_0dp"
                android:lineSpacingExtra="@dimen/_12sdp"
                android:text="@string/seperator_hyphen"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintHorizontal_weight="0.6"
                app:layout_constraintStart_toEndOf="@id/tvPrescrptionSeparator"
                app:layout_constraintTop_toTopOf="@id/tvPrescrptionlabel" />

            <androidx.constraintlayout.widget.Barrier
                android:id="@+id/barrier"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="tvPrescrptionlabel, tvPrescrptionText" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvTreatmentLabel"
                style="@style/TextStyle_Regular_16"
                android:layout_width="@dimen/_0dp"
                android:layout_marginTop="@dimen/_16sdp"
                android:text="@string/treatment_outcome"
                app:layout_constraintEnd_toStartOf="@id/tvTreatmentSeparator"
                app:layout_constraintHorizontal_weight="0.3"
                app:layout_constraintStart_toEndOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@id/barrier" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvTreatmentSeparator"
                style="@style/TextStyle_Regular_16"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:text="@string/separator_colon"
                app:layout_constraintEnd_toStartOf="@id/tvTreatmentText"
                app:layout_constraintHorizontal_weight="0.05"
                app:layout_constraintStart_toEndOf="@id/tvTreatmentLabel"
                app:layout_constraintTop_toTopOf="@id/tvTreatmentLabel" />

            <androidx.appcompat.widget.AppCompatSpinner
                android:id="@+id/tvTreatmentText"
                style="@style/Form_Spinner_Style"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintHorizontal_weight="0.6"
                app:layout_constraintStart_toEndOf="@id/tvTreatmentSeparator"
                app:layout_constraintTop_toTopOf="@id/tvTreatmentLabel" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvTreatmentError"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_regular"
                android:padding="@dimen/_5sdp"
                android:text="@string/default_user_input_error"
                android:textColor="@color/a_red_error"
                android:textSize="@dimen/_12ssp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="@id/tvTreatmentText"
                app:layout_constraintStart_toStartOf="@id/tvTreatmentText"
                app:layout_constraintTop_toBottomOf="@id/tvTreatmentText" />

            <androidx.constraintlayout.widget.Barrier
                android:id="@+id/barrier1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="tvTreatmentLabel,tvTreatmentError" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvNextMedicalReviewLabel"
                style="@style/TextStyle_Regular_16"
                android:layout_width="@dimen/_0dp"
                android:layout_marginTop="@dimen/_16sdp"
                android:text="@string/next_visit_date"
                app:layout_constraintEnd_toStartOf="@id/tvNextMedicalReviewSeparator"
                app:layout_constraintHorizontal_weight="0.3"
                app:layout_constraintStart_toEndOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@id/barrier1" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvNextMedicalReviewSeparator"
                style="@style/TextStyle_Regular_16"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:text="@string/separator_colon"
                app:layout_constraintEnd_toEndOf="@id/tvInvestigationSeparator"
                app:layout_constraintHorizontal_weight="0.05"
                app:layout_constraintStart_toStartOf="@id/tvInvestigationSeparator"
                app:layout_constraintTop_toTopOf="@id/tvNextMedicalReviewLabel" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvNextMedicalReviewLabelText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_8sdp"
                android:background="@drawable/edittext_background_selector"
                android:cursorVisible="false"
                android:drawableEnd="@drawable/ic_date_picker_calendar"
                android:gravity="start|center"
                android:paddingStart="@dimen/_10sdp"
                android:paddingEnd="@dimen/_0dp"
                android:textColor="@color/black"
                android:textSize="@dimen/_16ssp"
                app:layout_constraintBottom_toBottomOf="@id/tvNextMedicalReviewLabel"
                app:layout_constraintBottom_toTopOf="@id/tvNextMedicalReviewError"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintHorizontal_weight="0.6"
                app:layout_constraintStart_toEndOf="@id/tvNextMedicalReviewSeparator"
                app:layout_constraintTop_toTopOf="@id/barrier1" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvNextMedicalReviewError"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/_16sdp"
                android:fontFamily="@font/inter_regular"
                android:padding="@dimen/_5sdp"
                android:text="@string/default_user_input_error"
                android:textColor="@color/a_red_error"
                android:textSize="@dimen/_12ssp"
                android:visibility="invisible"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="@id/tvNextMedicalReviewLabelText"
                app:layout_constraintStart_toStartOf="@id/tvNextMedicalReviewLabelText"
                app:layout_constraintTop_toBottomOf="@id/tvNextMedicalReviewLabelText" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvClinicalNameLabel"
