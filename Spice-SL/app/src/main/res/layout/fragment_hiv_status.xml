<?xml version="1.0" encoding="utf-8"?>
<org.medtroniclabs.uhis.ui.common.FloatingDetectorFrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.medicalreview.PresentingComplaintsFragment">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardStatus"
        style="@style/CardView_Style"
        android:layout_width="match_parent"
        app:cardUseCompatPadding="true"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/_16sdp">

            <View
                android:id="@+id/viewStatusBG"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_0dp"
                android:background="@color/card_background"
                app:layout_constraintBottom_toBottomOf="@id/tvStatusTitle"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/centerRightGuideline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.50" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/centerLeftGuideline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.45" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/startGuideline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_begin="@dimen/_16sdp" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/endGuideline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_end="@dimen/_16sdp" />

            <androidx.constraintlayout.widget.Group
                android:id="@+id/pregnancyStatusGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:constraint_referenced_ids="tvPregnancyAndBreastFeedingStatusLabel,llPregnancyAndBreastFeedingStatus" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvStatusTitle"
                style="@style/Form_Header_Style"
                android:layout_width="@dimen/_0dp"
                android:gravity="center"
                android:paddingHorizontal="@dimen/_10sdp"
                android:paddingVertical="@dimen/_10sdp"
                android:text="@string/status"
                android:textSize="@dimen/_16ssp"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintStart_toStartOf="@id/startGuideline"
                app:layout_constraintTop_toTopOf="@id/viewStatusBG" />

            <androidx.constraintlayout.widget.Group
                android:id="@+id/tbGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:constraint_referenced_ids="tvTBStatus,etTBStatus" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvTBStatus"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_regular"
                android:paddingVertical="@dimen/_8sdp"
                android:text="@string/tb_status"
                android:textColor="@color/table_title"
                android:textSize="@dimen/_16ssp"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintStart_toStartOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@id/tvStatusTitle" />

            <androidx.appcompat.widget.AppCompatSpinner
                android:id="@+id/etTBStatus"
                style="@style/Form_Spinner_Style"
                android:layout_width="@dimen/_0dp"
                android:paddingBottom="@dimen/_4sdp"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintStart_toStartOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@id/tvTBStatus" />


            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvTBStatusError"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_regular"
                android:padding="@dimen/_5sdp"
                android:text="@string/error_label"
                android:textColor="@color/a_red_error"
                android:textSize="@dimen/_12ssp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintStart_toStartOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@id/etTBStatus" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvPregnancyAndBreastFeedingStatusLabel"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_regular"
                android:paddingVertical="@dimen/_8sdp"
                android:text="@string/pregnancy_bread_feeding_status"
                android:textColor="@color/table_title"
                android:textSize="@dimen/_16ssp"
                app:layout_constraintBottom_toTopOf="@id/llPregnancyAndBreastFeedingStatus"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintStart_toStartOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@+id/tvTBStatusError"/>

            <LinearLayout
                android:id="@+id/llPregnancyAndBreastFeedingStatus"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintStart_toStartOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@id/tvPregnancyAndBreastFeedingStatusLabel" />


            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvPregnancyAndBreastFeedingStatusError"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_regular"
                android:padding="@dimen/_5sdp"
                android:text="@string/error_label"
                android:textColor="@color/a_red_error"
                android:textSize="@dimen/_12ssp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintStart_toStartOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@id/llPregnancyAndBreastFeedingStatus" />

            <androidx.constraintlayout.widget.Group
                android:id="@+id/lmbGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:constraint_referenced_ids="tvLastMenstrualPeriodLabel,tvLastMenstrualPeriodDate" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvLastMenstrualPeriodLabel"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_regular"
                android:paddingVertical="@dimen/_8sdp"
                android:text="@string/last_menstrual_period"
                android:textColor="@color/table_title"
                android:textSize="@dimen/_16ssp"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintStart_toStartOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@id/tvPregnancyAndBreastFeedingStatusError" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvLastMenstrualPeriodDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:background="@drawable/edittext_background"
                android:drawableEnd="@drawable/calender"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:gravity="start|center"
                android:hint="@string/enter"
                android:paddingStart="@dimen/_10sdp"
                android:paddingEnd="@dimen/_0dp"
                android:textColor="@color/black"
                android:textSize="@dimen/_16ssp"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintStart_toStartOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@id/tvLastMenstrualPeriodLabel" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvLastMenstrualPeriodError"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_regular"
                android:padding="@dimen/_5sdp"
                android:text="@string/error_label"
                android:textColor="@color/a_red_error"
                android:textSize="@dimen/_12ssp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintStart_toStartOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@id/tvLastMenstrualPeriodDate" />

            <androidx.constraintlayout.widget.Barrier
                android:id="@+id/barrierOne"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="tvLastMenstrualPeriodError" />

            <androidx.constraintlayout.widget.Group
                android:id="@+id/gestationalAgeGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:constraint_referenced_ids="tvGestationalAgeLabel,etGestationalAge" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvGestationalAgeLabel"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                android:paddingVertical="@dimen/_8sdp"
                android:text="@string/gestational_in_weeks"
                android:textColor="@color/table_title"
                android:textSize="@dimen/_16ssp"
                app:layout_constraintEnd_toStartOf="@id/centerLeftGuideline"
                app:layout_constraintStart_toEndOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@id/barrierOne" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/etGestationalAge"
                style="@style/Form_Input_Style_BG"
                android:layout_width="@dimen/_0dp"
                android:hint="@string/enter"
                android:enabled="false"
                android:paddingHorizontal="@dimen/_12sdp"
                android:paddingVertical="@dimen/_10sdp"
                app:layout_constraintEnd_toStartOf="@id/centerLeftGuideline"
                app:layout_constraintStart_toEndOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@id/tvGestationalAgeLabel" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvGestationalAgeError"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_regular"
                android:padding="@dimen/_5sdp"
                android:text="@string/error_label"
                android:textColor="@color/a_red_error"
                android:textSize="@dimen/_12ssp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="@id/etGestationalAge"
                app:layout_constraintStart_toStartOf="@id/etGestationalAge"
                app:layout_constraintTop_toBottomOf="@id/etGestationalAge" />

            <androidx.constraintlayout.widget.Group
                android:id="@+id/expectedDateGroup"
                android:layout_width="wrap_content"
                android:visibility="gone"
                android:layout_height="wrap_content"
                app:constraint_referenced_ids="tvExpectedDate,etExpectedDate" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvExpectedDate"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                android:paddingVertical="@dimen/_8sdp"
                android:text="@string/expected_date_of_delivery"
                android:textColor="@color/table_title"
                android:textSize="@dimen/_16ssp"
                app:layout_constraintEnd_toStartOf="@id/endGuideline"
                app:layout_constraintStart_toEndOf="@id/centerRightGuideline"
                app:layout_constraintTop_toBottomOf="@id/barrierOne" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/etExpectedDate"
                style="@style/Form_Input_Style_BG"
                android:layout_width="@dimen/_0dp"
                android:hint="@string/enter"
                android:enabled="false"
                android:paddingHorizontal="@dimen/_12sdp"
                android:paddingVertical="@dimen/_10sdp"
                app:layout_constraintEnd_toStartOf="@id/endGuideline"
                app:layout_constraintStart_toEndOf="@id/centerRightGuideline"
                app:layout_constraintTop_toBottomOf="@id/tvExpectedDate" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvExpectedDateError"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_regular"
                android:padding="@dimen/_5sdp"
                android:text="@string/error_label"
                android:textColor="@color/a_red_error"
                android:textSize="@dimen/_12ssp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintStart_toStartOf="@id/etExpectedDate"
                app:layout_constraintTop_toBottomOf="@id/etExpectedDate" />

            <androidx.constraintlayout.widget.Barrier
                android:id="@+id/barrierTwo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="tvExpectedDateError,tvGestationalAgeError" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvAHDLabel"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                android:paddingVertical="@dimen/_8sdp"
                android:text="@string/ahd_status_advanced_hiv_status"
                android:textColor="@color/table_title"
                android:textSize="@dimen/_16ssp"
                app:layout_constraintBottom_toTopOf="@id/llAHD"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintStart_toStartOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@id/barrierTwo" />

            <LinearLayout
                android:id="@+id/llAHD"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintStart_toStartOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@id/tvAHDLabel" />


            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvAHDError"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_regular"
                android:padding="@dimen/_5sdp"
                android:text="@string/error_label"
                android:textColor="@color/a_red_error"
                android:textSize="@dimen/_12ssp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintStart_toStartOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@id/llAHD" />


            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvDSDLabel"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_regular"
                android:paddingVertical="@dimen/_8sdp"
                android:text="@string/dsd_status_differetiated_service_delivery_model_assigned"
                android:textColor="@color/table_title"
                android:textSize="@dimen/_16ssp"
                app:layout_constraintBottom_toTopOf="@id/llDSD"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintStart_toStartOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@id/tvAHDError" />

            <LinearLayout
                android:id="@+id/llDSD"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintStart_toStartOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@id/tvDSDLabel" />


            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvDSDError"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_regular"
                android:padding="@dimen/_5sdp"
                android:text="@string/error_label"
                android:textColor="@color/a_red_error"
                android:textSize="@dimen/_12ssp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintStart_toStartOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@id/llDSD" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvSelectModelLabel"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                android:paddingVertical="@dimen/_8sdp"
                android:text="@string/select_model"
                android:textColor="@color/table_title"
                android:textSize="@dimen/_16ssp"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintStart_toStartOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@id/tvDSDError" />

            <androidx.appcompat.widget.AppCompatSpinner
                android:id="@+id/etSelectModel"
                style="@style/Form_Spinner_Style"
                android:layout_width="@dimen/_0dp"
                android:paddingBottom="@dimen/_4sdp"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintStart_toStartOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@id/tvSelectModelLabel" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvSelectModelError"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_regular"
                android:padding="@dimen/_5sdp"
                android:text="@string/error_label"
                android:textColor="@color/a_red_error"
                android:textSize="@dimen/_12ssp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="@id/endGuideline"
                app:layout_constraintStart_toStartOf="@id/startGuideline"
                app:layout_constraintTop_toBottomOf="@id/etSelectModel" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

</org.medtroniclabs.uhis.ui.common.FloatingDetectorFrameLayout>
