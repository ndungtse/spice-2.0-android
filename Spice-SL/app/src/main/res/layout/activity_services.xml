<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context="org.medtroniclabs.uhis.ui.household.HouseholdSearchActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/search_background"
        app:layout_constraintTop_toTopOf="parent"
        tools:layout_editor_absoluteX="0dp">

        <include
            android:id="@+id/llExactSearch"
            layout="@layout/household_search_layout" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:id="@+id/view"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="@color/graph_limit_linecolor"
        app:layout_constraintTop_toBottomOf="@+id/clHeader" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvMembersCount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/_10sdp"
        android:fontFamily="@font/inter_bold"
        android:padding="@dimen/_5sdp"
        android:textColor="@color/house_hold_title"
        android:textSize="@dimen/_18ssp"
        android:visibility="visible"
        app:layout_constraintEnd_toStartOf="@id/llFilter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/llFilter"
        tools:text="@string/household_members" />

    <include
        android:id="@+id/llFilter"
        layout="@layout/filter_btn_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_10sdp"
        android:layout_marginEnd="@dimen/_16sdp"
        android:visibility="visible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/view" />

    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/filterBarrier"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="llFilter,tvMembersCount" />

    <androidx.appcompat.widget.AppCompatSpinner
        android:id="@+id/tvMemberTypes"
        style="@style/Form_Spinner_Style"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/_16sdp"
        android:layout_marginTop="@dimen/_16sdp"
        android:minHeight="@dimen/_40sdp"
        app:layout_constraintTop_toBottomOf="@id/filterBarrier" />

    <View
        android:id="@+id/viewMemberTypes"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_marginTop="@dimen/_16sdp"
        android:background="@color/graph_limit_linecolor"
        app:layout_constraintTop_toBottomOf="@+id/tvMemberTypes" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMembersList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="@dimen/_5sdp"
        android:visibility="visible"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/viewMemberTypes" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvNoMembersFound"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_0dp"
        android:gravity="center"
        android:paddingHorizontal="@dimen/_15sdp"
        android:text="@string/no_members_found"
        android:textColor="@color/medium_risk_color"
        android:textSize="@dimen/_16ssp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/viewMemberTypes" />

</androidx.constraintlayout.widget.ConstraintLayout>
